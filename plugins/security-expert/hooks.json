{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/check-security-skill.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__.*context7|mcp__.*exa",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/track-mcp-research.py"
          }
        ]
      }
    ]
  }
}
