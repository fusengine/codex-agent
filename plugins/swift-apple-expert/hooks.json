{
  "hooks": {
    "PreToolUse": [
      {
        "_description": "Block Swift edits if skill not consulted",
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/check-swift-skill.py"
          }
        ]
      },
      {
        "_description": "Validate Swift SOLID principles before Write/Edit",
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/validate-swift-solid.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "_description": "Track MCP research calls",
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/track-mcp-research.py"
          }
        ]
      }
    ]
  }
}
