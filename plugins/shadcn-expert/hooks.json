{
  "hooks": {
    "PreToolUse": [
      {
        "_description": "Block shadcn edits if skill not consulted",
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/check-skill-loaded.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "_description": "Track MCP research calls",
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/track-mcp-research.py"
          }
        ]
      }
    ]
  }
}
